[t-deposit] %switch2%
    title =  Energy deposition in xz mesh.
     mesh = xyz
   x-type =    2            # x-mesh is linear given bx xmin, xmax and nx
     xmin = -11.000000      # minimum value of x-mesh points
     xmax =  18.000000      # maximum value of x-mesh points
       nx =   c1            # number of x-mesh points
   y-type =    2            # y-mesh is linear given by ymin, ymax and ny
     ymin = -20.000000      # minimum value of y-mesh points
     ymax =  20.000000      # maximum value of y-mes    h points
       ny =    1            # number of y-mes       h points
   z-type =    2            # z-mesh is linear given by zmin, zmax and nz
     zmin =  -15.000000     # minimum value of z-mesh points
     zmax =   15.000000     # maximum value of z-mesh points
       nz =   c1            # number of z-mesh points
     axis =   xz            # axis of output
     file =  dose_xz.out    # file name of output for the above axis
     part =  all photon proton (alpha 7Li)
     unit =  0              # unit is [Gy/source]
   output =  dose
   epsout =  1

[t-deposit] %switch2%
    title =  Energy deposition in a box (1cmx1cm) along x-axis.
     mesh = xyz
   x-type =    2            # x-mesh is linear given bx xmin, xmax and nx
     xmin = -8.2800      # minimum value of x-mesh points
     xmax =  15.000000      # maximum value of x-mesh points
       nx =   c1            # number of x-mesh points
   y-type =    2            # y-mesh is linear given by ymin, ymax and ny
     ymin = -1.000000       # minimum value of y-mesh points
     ymax =  1.000000       # maximum value of y-mesh points
       ny =    1            # number of y-mesh points
   z-type =    2            # z-mesh is linear given by zmin, zmax and nz
     zmin =  -1.000000      # minimum value of z-mesh points
     zmax =   1.000000      # maximum value of z-mesh points
       nz =    1            # number of z-mesh points
     axis =   xz            #  axis of output
     file =  dose_xz_summed.out    # file name of output for the above axis
     part =  all photon proton (alpha 7Li)
     unit =  0              # unit is [Gy/source]
   output =  dose
   epsout =  1

$ the results are for skin, bone, csf&dura, nervous tissue, the tumor, skeletal, smooth muscle, fat, eyes, air inside cavities
[t-deposit] %switch2%
    title =  General energy deposition for respective tissues.
     mesh =  reg
      reg =  111 112 113 114 115 116 117 118 119 120
     axis =  reg            # axis of output
     file =  dose_reg.out   # file name of output for the above axis
     part =  all photon proton (alpha 7Li)
     unit =  0              # unit is [Gy/source]
   output =  dose
   epsout =  1


################################## HNB DOSES ###########################################
[t-track] %switch3%
    title = Hydrogen (1) Nitrogen (2) Boron (3) along z-axis.
     mesh =  xyz
   x-type =    2            # x-mesh is linear given bx xmin, xmax and nx
     xmin = -11.000000      # minimum value of x-mesh points
     xmax =  18.000000      # maximum value of x-mesh points
       nx =   1             # number of x-mesh points
   y-type =    2            # y-mesh is linear given by ymin, ymax and ny
     ymin = -25.000000      # minimum value of y-mesh points
     ymax =  10.000000      # maximum value of y-mesh points
       ny =   1             # number of y-mesh points
   z-type =    2            # z-mesh is linear given by zmin, zmax and nz
     zmin =  -13.00000      # minimum value of z-mesh points
     zmax =   15.00000      # maximum value of z-mesh points
       nz =   c1            # number of z-mesh points
     axis =  z              # axis of output
    e-type = 1              # e-mesh is given by the below data
        ne = 1              # number of e-mesh points
             0.0  1000.0
      file = hnb_z.out      # file name of output for the above axis
    epsout = 1
     angel = ymin(1.0e-18) ymax(1.0e-12)
     y-txt = Flux [MeV/cm^3/source]
      unit = 1              # unit is [1/cm^2/source]
multiplier = all 
     part  = neutron
     emax  = 2.000e+01
      mat        mset1                    mset2                   mset3
      all (9.6681e-012 2001 1 -4) (1.7910e-013 2002 1 -4) (9.6472e-17 2003 1 -4)

