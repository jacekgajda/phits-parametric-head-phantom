################################# DETECTOR TALLIES #####################################
[t-deposit] %switch4%
    title = Unbroadened Energy Deposition.
     mesh = reg
      reg = 121
     unit = 3               # unit is [1/source] 
   output = deposit         # total deposit energy
     axis = eng             # axis of output
   e-type = 2               # e-mesh is given by the below data
       ne = 1000             # number of e-mesh points
     emin = 0.0
     emax = 2.5
   y-txt  = Counts [1/source]      
     file = detector_dep.out    
     part = all          
   epsout = 1


[ T-Deposit ] %switch4%
    title = Energy Deposition with Gaussian smearing
     mesh =    reg          # mesh type is region-wise
      reg =    121
     unit =    3            # unit is [1/source] : only for output=deposit
   letmat =    0            # (D=0) material id for LET, 0: real material
  dedxfnc =    1            # (D=0) user defined multiplier, 0(no), 1, 2
 material =   all           # (D=all) number of specific material
   output =   deposit       # deposit enerygy distribution
   e-type =   2             # e-mesh is linear given by emin, emax and ne
     emin =   0.00000       # minimum value of e-mesh points
     emax =   2.50000       # maximum value of e-mesh points
       ne =   1000           # number of e-mesh points
     axis =   eng           # axis of outputP
     file =   detector_gaus.out     # file name of output for the above axis
     part =   all      
   y-txt  =  Counts [1/source]      
   epsout =   1             # (D=0) generate eps file by ANGEL
   dresol =  0.003          # (D=0) ; width = sqrt(dresol**2 + dfano*E) 
    dfano =  0.0001         # (D=0) width = sqrt(dresol**2 + dfano*E); https://www.berkeleynucleonics.com/lanthanum-bromide/ resolution = 3%

[ T-Deposit ] %switch4.1%
    title = Energy Deposition with custom Gaussian smearing
     mesh =    reg          # mesh type is region-wise
      reg =    121
     unit =    3            # unit is [1/source] : only for output=deposit
   letmat =    0            # (D=0) material id for LET, 0: real material
  dedxfnc =    1            # (D=0) user defined multiplier, 0(no), 1, 2
 material =   all           # (D=all) number of specific material
   output =   deposit       # deposit enerygy distribution
   e-type =   2             # e-mesh is linear given by emin, emax and ne
     emin =   0.00000       # minimum value of e-mesh points
     emax =   2.50000       # maximum value of e-mesh points
       ne =   1000          # number of e-mesh points
     axis =   eng           # axis of output
     file =   detector_gaus_mod.out     # file name of output for the above axis
     part =   all      
   y-txt  =  Counts [1/source]      
   epsout =     1             # (D=0) generate eps file by ANGEL
   dresol =    -1.0          # (D=0) ; width = sqrt(dresol**2 + dfano*E); https://www.berkeleynucleonics.com/lanthanum-bromide/ resolution = 3% 

################################# TUMOR TALLIES ########################################
[t-track] %switch5%
    title = Hydrogen (1) Nitrogen (2) Boron (3) - Tumor
     mesh = reg
      reg = 115
    e-type = 1              # e-mesh is given by the below data
        ne = 1              # number of e-mesh points
             0.0  1000.0
      axis = reg            # axis of output
      file = hnb_t.out      # file name of output for the above axis
    epsout = 1
     angel = ymin(1.0e-18) ymax(1.0e-12)
     y-txt = Dose [Gy/source]
      unit = 1              # unit is [1/cm^2/source]
multiplier = all 
     part  = neutron
     emax  = 2.000e+01
      mat        mset1                    mset2                   mset3
      all (9.6681e-012 2001 1 -4) (1.7910e-013 2002 1 -4) (9.6472e-17 2003 1 -4)

[t-deposit] %switch5%
    title =  General energy deposition the tumor.
     mesh =  reg
      reg =  115
    volume                  # combined, lattice or level structure 
    non     reg      vol    # reg definition
    1       115     (4/3)*pi*c66**3
     axis =  reg            # axis of output
     file =  dose_t.out   # file name of output for the above axis
     part =  all photon proton (alpha 7Li)
     unit =  0              # unit is [Gy/source]
   output =  dose
   epsout =  1

[t-track] %switch5%
    title = Energy spectrum of neutrons in the tumor.
     mesh = reg
      reg = 115
     unit = 2               # unit is [1/source] 
     axis = eng             # axis of output
   e-type = 2               # e-mesh is given by the below data
       ne = 100             # number of e-mesh points
     emin = 0
     emax = c72
     file = tumor_spectrum.out  
     part = neutron          
    gshow = 1
   epsout = 1


