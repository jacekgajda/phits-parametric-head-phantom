$$$        SIMULATION PARAMETERS       $$$
set: c72[50.0E-03]
$the energy of projected neutrons

set: c73[-9.0]
$the placement x0 of the beam (-19,-9)

set: c74[-5.8]
$the placement x0 of the tumor (0,-5.8) (the detector will always be positioned as if the tumor were at -5.8)

set: c1[400] 
$600 - detailed & 1 min., 400 - optimal & 30 s, 200 - general & 10 s

set: c84[0.5]
$skull thickness which regulates shape of bone, muscle, fat and skin (0.25,1.5)


$$$        SWITCHES FOR TALLIES       $$$
set: %switch%[on]
$the switch turns "on" or "off" t-tracks for flux analysis// graphics 

set: %switch2%[off]
$the switch turns "on" or "off" dose calculation across the whole model

set: %switch3%[off]
$the switch turns "on" or "off" hnb doses

set: %switch4%[off]
$the switch turns "on" or "off" detector tallies

set: %switch4.1%[off]
$the switch turns "on" or "off" spectrum with gaussian smearing, using usrresol.f

set: %switch5%[off]         
$the switch turns "on" or "off" calculations for the tumor

[ T i t l e ]
Sample input for BNCT calculation


[ P a r a m e t e r s ]
 icntl    =           0     # (D=0) 3:ECH 5:NOR 6:SRC 7,8:GSH 11:DSH 12:DUMP
 maxcas   =           2000    # (D=10) number of particles per one batch 20000 
 maxbch   =           100     # (D=10) number of batches 100
 ireschk  =           1     # (D=0) Restart, 0:Check consistency, 1:No check
 e-mode   =           2     # 0: sampling mode; 1: adds evaporation;  2: adds also accurate charged particle yields and accurate neutron  energy distribution
 itall    =           1     
 negs     =           1 
 ipegs    =           0     #  Delete all PEGS5 output files when PHITS calculation is finished. Some files remain when the user self-terminates the PHITS calculation


[ S o u r c e ] 
   s-type = 26              # mono-energetic axial source
      suf = 56
      cut = -57
     proj = neutron         # kind of incident nucleus          
       e0 =  c72            # energy of beam [MeV/u]
      dir =   1.0           # z-direction of beam [cosine]
      dom =   0.0
      phi =   all


[ M a t e r i a l ]
$ Source: Table 4.4. in Report 44 of Journal of the International Commission on Radiation Units and Measurements , Volume 23 (1) – Jan 15, 1989

mat[1]                                                      $Air, Dry (near sea level)
            C         -0.000124 
            N         -1.0
            O         -0.231781
            Ar        -0.012827                           

mat[2]                                                      $Skin (ICRU-44)
            H        -0.10
            C        -0.204
            N        -0.042
            O        -0.645
            Na       -0.002
            P        -0.001
            S        -0.002
            Cl       -0.003
            K        -0.001

mat[3]                                                      $Skeleton, Spongiosa (33 cortical, 67 marrow (50 red 50 yellow) (ICRU-44) 
            H        -0.085
            C        -0.404
            N        -0.028
            O        -0.367
            Na       -0.001
            Mg       -0.001
            P        -0.034
            S        -0.002
            Cl       -0.002
            K        -0.001
            Ca       -0.074
            Fe       -0.001

    
mat[4]                                                      $Water, Liquid
            H       -0.111898
            O       -0.888102

mat[5]                                                      $Brain, Grey/White Matter (50:50) (ICRU-44)
            H        -0.107
            C        -0.145
            N        -0.022
            O        -0.712
            Na       -0.002
            P        -0.004
            S        -0.002
            Cl       -0.003
            K        -0.003


mat[6]                                                      $Tumor 
            H        -0.107                                 
            C        -0.145
            N        -0.022
            O        -0.712
            Na       -0.002
            P        -0.004
            S        -0.002
            Cl       -0.003
            K        -0.003
           10B       -1.147E-2                             

mat[7]                                                      $Muscle, Skeletal (ICRU-44) 
            H        -0.102
            C        -0.143
            N        -0.034
            O        -0.71
            Na       -0.001
            P        -0.002
            S        -0.003
            Cl       -0.001
            K        -0.004


mat[8]                                                      $Muscle, Striated (ICRU-44) - adnotes
            H        -0.102
            C        -0.123
            N        -0.031
            O        -0.729
            Na       -0.001
            P        -0.002
            S        -0.003
            Cl       -0.001
            K        -0.004


mat[9]                                                      $Adipose Tissue (ICRU-44)
            H        -0.114000
            C        -0.598000
            N        -0.007000
            O        -0.278000
            Na       -0.001000
            S        -0.001000
            Cl       -0.001000


mat[10]                                                     $Water, Liquid
            H       -0.111898
            O       -0.888102
mt10   lwtr.20t


mat[11]                                                     $Lanthanum (III) bromide                                                 
            57138    0.25
            35079    0.75

mat[12]                                                     $Aluminium coverage                                                 
            Al      -1.0
           
Mat[2001]     H  1.0  
Mat[2002]     N  1.0  
Mat[2003]   10B  1.0  

[ Mat Name Color ]
    mat   name                   color
     1    Air                    white
     2    Skin                   pastelpink
     3    Skeleton               gray
     4    CSF                    pastelblue
     5    Brain\,tissue          pink
     6    Tumor\,+\,\{^1^0\}B    darkred
     7    Skeletal\,muscles      red
     8    Smooth\,muscles        winered
     9    Adipose\,tissue        {0.867}  
     10   Eyes                   yellow
     11   \{Detector\}           pastelcyan
     12   Detector\,covering     gray


[ S u r f a c e ]
$   Source: https://phits.jaea.go.jp/manual/manualE-phits.pdf?
$$$        THICKNESS OF FACIAL STRUCTURES:       $$$ 
$   c8 - bone, c15 - skeletal,  c22 - fat, c29 - skin, c2 - smooth muscles;
set: c8[.75] c15[0.4] c22[0.25] c29[0.15]  

set: c2[4.00] c3[-14.00] c4[1.49] c5[-7.5] c6[5.0] c7[7.5] c9[c2+c8] c10[c3] c11[c4-2*c8] c12[c5-2*c8] c13[c6+10*c8] c14[c7+4*c8] 
set: c16[c9+c15] c17[c10-c15] c18[c11-c15] c19[c12-2*c15] c20[c13+2*c15] c21[c14+2*c15] c23[c16+c22] c24[c17-c22] c25[c18-c22] c26[c19-2*c22] c27[c20+2*c22] c28[c21+2*c22] c30[c23+c29]
set: c31[c24-c29] c32[c25-c29] c33[c26-2*c29] c34[c27+2*c29] c35[c28+2*c29] 


$$$        THICKNESS OF NECK STRUCTURES:       $$$
$   c36 - nervous tissue, c37 - CSF,  c39 - bone, c41 - skeletal muscles, c43 - fat, c45 - skin;
set: c36[0.5] c37[0.25] c39[0.5] c41[2.5] c43[1.00] c45[0.25] 

set: c38[c36+c37] c40[c38+c39] c42[c40+c41] c44[c42+c43] c46[c44+c45] c70[22.0] c71[c70-c37] 


$$$        EYES:       $$$
$   c47 - x, c51 - y, c49 - z;
set: c47[2.5] c48[-4.0] c49[10.2] 


$$$        NOSE:       $$$
$   skin: 
$   c50 - z_min, c52 - z_max, c51 - y_max, c53 - y_min;
set: c50[c32+c35] c51[c48+0.5] c52[c50+2.0] c53[c51-4.5]
$   fat: 
$   c54 - z_min, c55 - z_max, c55 - y_max, c57 - y_min;
set: c54[c50-c29] c55[c51-1.9*c29] c56[c52-c29] c57[c53+c29]


$$$        TUMOR RELATED:       $$$
$   tumor: 
$   c66 - r ; c59 - z; c69 - y; c68 - x (this is a dummy parameter for controlling the rotation of the detector)
set: c66[1] c59[0.0] c68[-5.8] c69[0.0]
$ detector:
$   LaBr3: 
$   y - c58, z - c59, x - c60, r - c61, vec(x) - c67; 
set: c58[0.0] c60[-18.0] c61[2.56] c67[2*c61]
$   Al: 
$   x0- c64, vec(x) - c65 r - c63, thickness - c62;
set:   c62[0.5] c63[c61+c62] c64[c60-c62] c65[c67+2*c62] 


$$$        PARAMETER MATH       $$$
set: c76[-4.01193] c77[20.99587] c78[-20.14898] c79[23.11667] c80[-11.86446] c81[22.05627] c82[-16.99166] c83[22.71902]
set: c75[c76-c84*c77] c85[c78-c84*c79] c86[c80-c84*c81] c87[c82-c84*c83] 


    
